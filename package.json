{
    "name": "@aaron-pienza/mcp-server-salesforce",
    "version": "1.0.1",
    "description": "MCP server for Salesforce — query, analytics, Apex, REST API passthrough, and more.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "bin": {
        "mcp-server-salesforce": "dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc && shx chmod +x dist/*.js",
        "prepare": "npm run build",
        "watch": "tsc --watch",
        "test": "node --test"
    },
    "keywords": [
        "mcp",
        "salesforce",
        "claude",
        "ai",
        "model-context-protocol",
        "jsforce",
        "soql",
        "apex",
        "reports",
        "dashboards"
    ],
    "author": "Aaron Pienza <aaron@inflection.io>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/aaron-pienza/mcp-server-salesforce.git"
    },
    "homepage": "https://github.com/aaron-pienza/mcp-server-salesforce#readme",
    "engines": {
        "node": ">=18.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "1.26.0",
        "dotenv": "17.3.1",
        "jsforce": "^3.10.3"
    },
    "devDependencies": {
        "@types/node": "25.3.0",
        "shx": "^0.4.0",
        "typescript": "^5.7.2"
    }
}
